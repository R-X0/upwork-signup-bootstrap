# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Postgres where created accounts are saved (Railway). Use the PUBLIC url when
# running from an external machine. This is the ONLY var a no-phone run needs.
DATABASE_URL=

# TextVerified V2 (phone/SMS) — OPTIONAL: only needed if you re-enable the phone
# step. The default pipeline bypasses phone verification, so leave these blank.
TV_API_KEY=
TV_USER=
TV_BASE=https://www.textverified.com

# CapSolver (reCAPTCHA token minting — research only)
CAPSOLVER_KEY=

# eldenstats Cloudflare email worker
EMAIL_WORKER=https://email-worker.eldenstats-email.workers.dev
EMAIL_DOMAIN=eldenstats.com

# Upwork signup
SIGNUP_URL=https://www.upwork.com/nx/signup/?dest=home
RECAPTCHA_SITEKEY=

# IPRoyal residential proxy — OPTIONAL (only the old upwork_signup.py GraphQL path uses it)
IPROYAL_USER=
IPROYAL_PASS=
IPROYAL_COUNTRY=us
